      <aliases enabled='yes' />
      <column caption='Faixa Etária' datatype='string' name='[Calculation_0073749725200384]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [idade] &lt; 25 THEN &quot;18-24&quot;&#10;ELSEIF [idade] &lt; 35 THEN &quot;25-34&quot;&#10;ELSEIF [idade] &lt; 45 THEN &quot;35-44&quot;&#10;ELSEIF [idade] &lt; 55 THEN &quot;45-54&quot;&#10;ELSE &quot;55+&quot;&#10;END' />
      </column>
      <column caption='Faixa Tempo Empresa' datatype='string' name='[Calculation_0073749726978049]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [anos_empresa] &lt; 1 THEN &quot;&lt; 1 ano&quot;&#10;ELSEIF [anos_empresa] &lt; 3 THEN &quot;1-3 anos&quot;&#10;ELSEIF [anos_empresa] &lt; 5 THEN &quot;3-5 anos&quot;&#10;ELSE &quot;5+ anos&quot;&#10;END' />
      </column>
      <column caption='Variação de Custo 2024 x 2025' datatype='string' name='[Calculation_0141439300096000]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF&#10;&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [custo_total]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;&#10;&lt; 0&#10;&#10;THEN&#10;&#10;&quot;▼ Queda de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;ABS(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [custo_total]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;ELSE&#10;&#10;&quot;▲ Aumento de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [custo_total]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;END' />
      </column>
      <column caption='Cor Variação' datatype='string' name='[Calculation_0141439307079682]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AGG([Calculation_0141439300096000]) &gt; 0 THEN&#10;    &quot;Positivo&quot;&#10;ELSEIF AGG([Calculation_0141439300096000]) &lt; 0 THEN&#10;    &quot;Negativo&quot;&#10;ELSE&#10;    &quot;Neutro&quot;&#10;END' />
      </column>
      <column caption='Variação de Salário 2024 x 2025 (cópia)' datatype='string' name='[Variação de Custo 2024 x 2025 (cópia)_0141439303397377]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF&#10;&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [salario_base]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;&#10;&lt; 0&#10;&#10;THEN&#10;&#10;&quot;▼ Queda de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;ABS(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [salario_base]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;ELSE&#10;&#10;&quot;▲ Aumento de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [salario_base]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;END' />
      </column>
