    <worksheet name='Variação de Salário 2024 x 2025'>
      <table>
        <view>
          <datasources>
            <datasource caption='payroll_analytics' name='federated.0pr0eoh1fvctpj18t7cgq0z2kr19' />
          </datasources>
          <datasource-dependencies datasource='federated.0pr0eoh1fvctpj18t7cgq0z2kr19'>
            <column caption='Variação de Salário 2024 x 2025 (cópia)' datatype='string' name='[Variação de Custo 2024 x 2025 (cópia)_0141439303397377]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF&#10;&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [salario_base]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;&#10;&lt; 0&#10;&#10;THEN&#10;&#10;&quot;▼ Queda de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;ABS(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [salario_base]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;ELSE&#10;&#10;&quot;▲ Aumento de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [salario_base]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [salario_base]&#10;END&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;END' />
            </column>
            <column caption='Cargo' datatype='string' name='[cargo]' role='dimension' type='nominal' />
            <column datatype='date' name='[data_admissao]' role='dimension' type='ordinal' />
            <column caption='Departamento' datatype='string' name='[departamento]' role='dimension' type='nominal' />
            <column-instance column='[cargo]' derivation='None' name='[none:cargo:nk]' pivot='key' type='nominal' />
            <column-instance column='[departamento]' derivation='None' name='[none:departamento:nk]' pivot='key' type='nominal' />
            <column-instance column='[sexo]' derivation='None' name='[none:sexo:nk]' pivot='key' type='nominal' />
            <column caption='Salario Base' datatype='real' name='[salario_base]' role='measure' type='quantitative' />
            <column datatype='string' name='[sexo]' role='dimension' type='nominal' />
            <column-instance column='[Variação de Custo 2024 x 2025 (cópia)_0141439303397377]' derivation='User' name='[usr:Variação de Custo 2024 x 2025 (cópia)_0141439303397377:nk]' pivot='key' type='nominal' />
