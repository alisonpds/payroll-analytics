    <worksheet name='Variação de Custo 2024 x 2025'>
      <table>
        <view>
          <datasources>
            <datasource caption='payroll_analytics' name='federated.0pr0eoh1fvctpj18t7cgq0z2kr19' />
          </datasources>
          <datasource-dependencies datasource='federated.0pr0eoh1fvctpj18t7cgq0z2kr19'>
            <column caption='Variação de Custo 2024 x 2025' datatype='string' name='[Calculation_0141439300096000]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF&#10;&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [custo_total]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;&#10;&lt; 0&#10;&#10;THEN&#10;&#10;&quot;▼ Queda de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;ABS(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [custo_total]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;ELSE&#10;&#10;&quot;▲ Aumento de &quot;&#10;+&#10;STR(&#10;ROUND(&#10;(&#10;(&#10;SUM(&#10;IF YEAR([data_admissao]) = 2025 THEN [custo_total]&#10;END&#10;)&#10;-&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;)&#10;/&#10;SUM(&#10;IF YEAR([data_admissao]) = 2024 THEN [custo_total]&#10;END&#10;)&#10;) * 100&#10;,2)&#10;)&#10;+&#10;&quot;% entre 2024 e 2025&quot;&#10;&#10;END' />
            </column>
            <column caption='Cargo' datatype='string' name='[cargo]' role='dimension' type='nominal' />
            <column caption='Custo Total' datatype='real' name='[custo_total]' role='measure' type='quantitative' />
            <column datatype='date' name='[data_admissao]' role='dimension' type='ordinal' />
            <column caption='Departamento' datatype='string' name='[departamento]' role='dimension' type='nominal' />
            <column-instance column='[cargo]' derivation='None' name='[none:cargo:nk]' pivot='key' type='nominal' />
            <column-instance column='[departamento]' derivation='None' name='[none:departamento:nk]' pivot='key' type='nominal' />
